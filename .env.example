# Morpheus Marketplace - Environment Variables
# Copy this file to .env.local for local development

# ============================================
# PUBLIC VARIABLES (exposed to browser)
# ============================================

# App URL (optional - auto-detected from request origin for Amplify/Vercel)
# Only set this if you need to override the automatic detection
# Leave blank for Amplify hosting - it will use the request origin automatically
NEXT_PUBLIC_APP_URL=

# Backend API URL
NEXT_PUBLIC_API_BASE_URL=https://api.mor.org

# ============================================
# COINBASE BUSINESS PAYMENT LINK INTEGRATION
# ============================================

# Webhook secret for verifying Coinbase Business Payment Link webhook signatures
# Format: X-Hook0-Signature header with HMAC-SHA256
# Configure in Coinbase Developer Portal → Webhooks
COINBASE_PAYMENT_LINK_WEBHOOK_SECRET=your_payment_link_webhook_secret_here

# NOTE: CDP API keys (CDP_API_KEY_NAME, CDP_API_KEY_PRIVATE_KEY) are configured
# on the backend (Morpheus-Marketplace-API). The frontend creates payment links
# through the backend admin API using ADMIN_API_SECRET for authentication.

# ============================================
# STRIPE PAYMENT INTEGRATION
# ============================================

STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Payment Link URL (required for Add Funds / Credit Card flow)
# Create at: Stripe Dashboard → Products → Payment Links
# Example: https://buy.stripe.com/test_xxx or https://buy.stripe.com/xxx for live
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_xxx

# ============================================
# BACKEND API ACCESS
# ============================================

# Admin secret for privileged API calls (e.g., credit adjustments)
# This should be a long, random string - KEEP THIS SECRET!
ADMIN_API_SECRET=your_secure_admin_secret_here

# ============================================
# AUTHENTICATION
# ============================================

# AWS Cognito (if using)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_...
NEXT_PUBLIC_COGNITO_CLIENT_ID=...
COGNITO_CLIENT_SECRET=...

# OAuth providers
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ============================================
# DATABASE (if applicable)
# ============================================

DATABASE_URL=postgresql://...
DATABASE_DIRECT_URL=postgresql://...

# ============================================
# MONITORING & LOGGING
# ============================================

# Sentry (error tracking)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Set to true to enable debug logging
DEBUG=false

# Set to true to skip webhook signature verification (NEVER IN PRODUCTION!)
SKIP_WEBHOOK_VERIFICATION=false

# ============================================
# MAINTENANCE MODE
# ============================================

# Set to true to redirect all page routes to the maintenance page
IS_MAINTENANCE_MODE=false

# ============================================
# NOTES
# ============================================

# 1. Never commit .env.local to git!
# 2. Use Vercel/deployment platform for production secrets
# 3. Rotate secrets regularly (every 90 days)
# 4. Use different secrets for dev/staging/production
# 5. Coinbase Commerce API is deprecated - migrate to Payment Links API
