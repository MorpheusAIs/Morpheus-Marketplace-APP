# Morpheus Marketplace - Environment Variables
# Copy this file to .env.local for local development

# ============================================
# PUBLIC VARIABLES (exposed to browser)
# ============================================

# App URL (optional - auto-detected from request origin for Amplify/Vercel)
# Only set this if you need to override the automatic detection
# Leave blank for Amplify hosting - it will use the request origin automatically
NEXT_PUBLIC_APP_URL=

# Backend API URL
NEXT_PUBLIC_API_BASE_URL=https://api.mor.org

# Feature flags
NEXT_PUBLIC_COINBASE_USE_PAYMENT_LINKS=false

# ============================================
# COINBASE PAYMENT INTEGRATION
# ============================================

# OLD Coinbase Commerce API (deprecated - to be removed)
# Docs: https://commerce.coinbase.com/docs/api/
COINBASE_COMMERCE_API_KEY=your_commerce_api_key_here
COINBASE_COMMERCE_WEBHOOK_SECRET=your_commerce_webhook_secret_here

# NEW Payment Links API (preferred)
# Docs: https://docs.cdp.coinbase.com/coinbase-business/payment-link-apis/overview
# Uses CDP API keys with JWT Bearer token authentication
COINBASE_CDP_KEY_NAME=organizations/{org_id}/apiKeys/{key_id}
COINBASE_CDP_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_MULTI_LINE_PRIVATE_KEY\n-----END EC PRIVATE KEY-----\n"
COINBASE_WEBHOOK_SECRET=your_payment_links_webhook_secret_here

# Permission required: "View" scope (includes Payment Links API access)
# NO special "onramp" permissions needed - just "View" is sufficient

# ============================================
# STRIPE PAYMENT INTEGRATION
# ============================================

STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Payment Link URL (required for Add Funds / Credit Card flow)
# Create at: Stripe Dashboard → Products → Payment Links
# Example: https://buy.stripe.com/test_xxx or https://buy.stripe.com/xxx for live
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_xxx

# ============================================
# BACKEND API ACCESS
# ============================================

# Admin secret for privileged API calls (e.g., credit adjustments)
# This should be a long, random string - KEEP THIS SECRET!
ADMIN_API_SECRET=your_secure_admin_secret_here

# ============================================
# AUTHENTICATION
# ============================================

# AWS Cognito (if using)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_...
NEXT_PUBLIC_COGNITO_CLIENT_ID=...
COGNITO_CLIENT_SECRET=...

# OAuth providers
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ============================================
# DATABASE (if applicable)
# ============================================

DATABASE_URL=postgresql://...
DATABASE_DIRECT_URL=postgresql://...

# ============================================
# MONITORING & LOGGING
# ============================================

# Sentry (error tracking)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Set to true to enable debug logging
DEBUG=false

# Set to true to skip webhook signature verification (NEVER IN PRODUCTION!)
SKIP_WEBHOOK_VERIFICATION=false

# ============================================
# NOTES
# ============================================

# 1. Never commit .env.local to git!
# 2. Use Vercel/deployment platform for production secrets
# 3. Rotate secrets regularly (every 90 days)
# 4. Use different secrets for dev/staging/production
# 5. Coinbase Commerce API is deprecated - migrate to Payment Links API
